<%- include('../partials/header') %>
  <main id="main">

    <section class="page-hero">
      <p class="eyebrow au">What's On</p>
      <h1 class="au au-d1">Events</h1>
      <p class="page-hero__sub au au-d2">From night safaris to wildlife photography masterclasses there is always
        something extraordinary happening at WildVista.</p>
    </section>

    <div class="ibar" role="note">
      <span class="pulsedot pulsedot--sm" aria-hidden="true"></span>
      Open every day &mdash; <strong>9:00 AM &ndash; 6:00 PM</strong>
    </div>

    <section class="ev-filters js-reveal" aria-label="Filter events">
      <div class="ev-filters__inner">

        <div class="ev-filter-group">
          <label class="ev-filter-label" for="yearSelect">Year</label>
          <div class="ev-select-wrap">
            <select id="yearSelect" aria-label="Select year">
              <% years.forEach(function(y) { %>
                <option value="<%= y %>" <%=y===selectedYear ? 'selected' : '' %>><%= y %>
                </option>
                <% }); %>
            </select>
          </div>
        </div>

        <div class="ev-filter-group">
          <label class="ev-filter-label">Category</label>
          <div class="ev-cat-btns" id="catBtns" role="group" aria-label="Filter by category">
            <button class="ev-cat-btn <%= selectedCategory === 'all' ? 'active' : '' %>" data-cat="all">All</button>
            <button class="ev-cat-btn <%= selectedCategory === 'Seasonal Celebration' ? 'active' : '' %>"
              data-cat="Seasonal Celebration">Seasonal</button>
            <button class="ev-cat-btn <%= selectedCategory === 'Conservation Talk' ? 'active' : '' %>"
              data-cat="Conservation Talk">Conservation</button>
            <button class="ev-cat-btn <%= selectedCategory === 'Family Activity' ? 'active' : '' %>"
              data-cat="Family Activity">Family</button>
          </div>
        </div>

      </div>
    </section>

    <section class="ev-section" aria-label="Events list" aria-live="polite">
      <div class="ev-list" id="evList">
        <div class="ev-loading" id="evLoading">
          <div class="spinner"></div>
          <p>Loading events...</p>
        </div>
      </div>
    </section>

  </main>

  <script>
    var initialYear = '<%= selectedYear %>';
    var initialCat = '<%= selectedCategory %>';
  </script>
  <%- include('../partials/footer') %>